# Sanity — criar projeto com `npx sanity init` (ou em sanity.io/manage) e preencher:
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Web3Forms — formulário de Contact (envio estático, sem backend).
# Gerar grátis em https://web3forms.com colando o e-mail de destino. A key é pública.
PUBLIC_WEB3FORMS_KEY=
