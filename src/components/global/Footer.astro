---
// Footer — Fase 2. Fiel ao Figma Home (node 3089:2), responsivo desktop/tablet/mobile.
// Conteúdo hardcoded aqui; Fase 4 troca por siteSettings do Sanity (nav, donateUrl, legal, social).

const nav = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/programs', label: 'Programs' },
  { href: '/stories', label: 'Stories' },
  { href: '/volunteer', label: 'Volunteer' },
  { href: '/donate', label: 'Donate' },
  { href: '/contact', label: 'Contact' },
];

const legal = [
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms of Service' },
  { href: '/cookies', label: 'Cookies Settings' },
];

const donateUrl = '/donate'; // Fase 4: siteSettings.donateUrl (provedor externo)
const year = new Date().getFullYear();

const path = Astro.url.pathname;
const isCurrent = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(`${href}/`);
---

<footer class="relative overflow-hidden bg-brand text-orchid">
  {/* Papel picado — faixa decorativa topo */}
  <div class="papel papel--top" aria-hidden="true"></div>

  <div
    class="relative z-10 mx-auto grid max-w-[120rem] grid-cols-1 gap-x-16 gap-y-12 px-6 pb-24 pt-28 sm:px-10 lg:grid-cols-2 lg:items-end lg:px-[3.875rem] lg:pb-28 lg:pt-36"
  >
    {/* Logo */}
    <div class="lg:self-center">
      <img
        src="/images/footer/logo.svg"
        alt="La Mano Solidária — Elva Fonseca Foundation"
        width="632"
        height="472"
        class="h-auto w-48 md:w-64 lg:w-[28rem]"
      />
    </div>

    {/* Bloco direito: nav → título → (botão donate mobile) → legal */}
    <div class="flex flex-col items-start gap-8">
      <nav aria-label="Footer">
        <ul class="grid grid-cols-1 gap-x-12 gap-y-1.5 sm:grid-flow-col sm:grid-rows-4 lg:gap-x-16">
          {
            nav.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  aria-current={isCurrent(href) ? 'page' : undefined}
                  class="footer-navlink inline-flex py-2 font-display text-2xl uppercase tracking-[-0.04em] transition-opacity hover:opacity-70 aria-[current=page]:opacity-60"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <p class="font-display font-black text-[2.75rem] leading-none tracking-[-0.04em] sm:text-6xl lg:text-[5.75rem]">
        LA MANO<br />SOLIDÁRIA.
      </p>

      {/* CTA Donate — mobile (a aba vertical some abaixo de md) */}
      <a
        href={donateUrl}
        class="flex min-h-11 w-full items-center justify-center rounded-md bg-orchid px-6 py-3 font-display text-lg uppercase tracking-[-0.02em] text-jacko-bean-950 transition-opacity hover:opacity-90 md:hidden"
      >
        Donate
      </a>

      {/* Linha legal + crédito */}
      <div class="flex flex-col flex-wrap items-start gap-x-6 gap-y-3 sm:flex-row sm:items-center">
        <ul class="flex flex-wrap gap-x-6 gap-y-2">
          {
            legal.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="footer-legal text-[0.9375rem] font-semibold transition-opacity hover:opacity-70"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
        <a
          href="https://carthagos.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-[0.9375rem] transition-opacity hover:opacity-70"
        >
          <span class="opacity-80">designed by</span>
          <img src="/images/footer/crt.svg" alt="Carthagos" width="62" height="18" class="h-[1.1em] w-auto" />
        </a>
      </div>
    </div>
  </div>

  {/* Papel picado — faixa decorativa base */}
  <div class="papel papel--bottom" aria-hidden="true"></div>

  {/* Aba vertical Donate — desktop/tablet (md+); no mobile vira o botão acima */}
  <a
    href={donateUrl}
    class="donate-tab hidden md:flex"
    aria-label="Donate"
  >
    <span class="donate-tab__text">Donate</span>
  </a>

  <p class="sr-only">© {year} Elva Fonseca Foundation</p>
</footer>

<style>
  .papel {
    position: absolute;
    left: 0;
    right: 0;
    height: 3rem;
    background-image: url('/images/footer/papel-picado.png');
    background-repeat: repeat-x;
    background-size: auto 100%;
    pointer-events: none;
  }
  .papel--top {
    top: 0;
    background-position: left top;
  }
  .papel--bottom {
    bottom: 0;
    background-position: left bottom;
    transform: scaleY(-1);
  }
  @media (min-width: 768px) {
    .papel { height: 4rem; }
  }
  @media (min-width: 1024px) {
    .papel { height: 5rem; }
  }

  /* Aba vertical (borda direita, centrada) */
  .donate-tab {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 0.625rem;
    border-top-left-radius: var(--radius-md);
    border-bottom-left-radius: var(--radius-md);
    background: var(--color-orchid);
    color: var(--color-jacko-bean-950);
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1rem;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    transition: padding-right 0.2s ease;
  }
  .donate-tab:hover {
    padding-right: 0.875rem;
  }
  .donate-tab__text {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .donate-tab { transition: none; }
  }
</style>
