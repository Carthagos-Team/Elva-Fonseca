---
// Hero — Fase 2. Reutilizável em Home, About, Programs, Volunteer, Donate, Stories
// (NÃO em Contact/Thank You). Fiel ao Figma (node 3107:2478).
// Card de imagem arredondado + overlay escuro; conteúdo ancorado embaixo. O Header
// (global) flutua sobreposto no topo — por isso o conteúdo é bottom-aligned.

interface Props {
  titleLines: string[];
  subcopy?: string;
  image?: string;
  imageAlt?: string;
  overlay?: number; // 0–1, default 0.16 (Figma)
  cta?: { label: string; href: string };
}

const {
  titleLines,
  subcopy,
  image = '/images/hero/home.webp',
  imageAlt = '',
  overlay = 0.16,
  cta,
} = Astro.props;
---

<section class="bg-surface px-4 pt-4 sm:px-5">
  <div class="relative flex h-[36rem] items-end justify-center overflow-hidden rounded-2xl md:h-[42rem] lg:h-[47rem]">
    <img
      src={image}
      alt={imageAlt}
      class="absolute inset-0 h-full w-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0" style={`background-color: rgba(0,0,0,${overlay})`} aria-hidden="true"></div>

    <div class="relative z-10 flex flex-col items-center gap-4 px-6 pb-10 text-center text-orchid lg:pb-16">
      <h1 class="font-display font-black uppercase leading-[1.05] tracking-[-0.04em] text-[2.75rem] sm:text-6xl lg:text-[6.2rem]">
        {titleLines.map((line, i) => (
          <>
            {line}
            {i < titleLines.length - 1 && <br />}
          </>
        ))}
      </h1>

      {
        subcopy && (
          <p class="max-w-[49rem] text-base font-medium leading-relaxed tracking-[-0.02em] text-orchid/95 sm:text-lg">
            {subcopy}
          </p>
        )
      }

      {
        cta && (
          <a
            href={cta.href}
            class="mt-2 inline-flex min-h-11 items-center justify-center rounded-md bg-orchid px-6 py-3.5 font-display font-black text-base uppercase tracking-[-0.01em] text-ink transition-transform duration-150 ease-out active:scale-[0.97]"
          >
            {cta.label}
          </a>
        )
      }
    </div>
  </div>
</section>
