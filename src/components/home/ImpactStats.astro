---

<section data-reveal-section class="bg-surface">
  <div class="mx-auto flex max-w-[120rem] flex-col items-center gap-10 px-6 py-16 text-center sm:px-10 lg:gap-16 lg:px-16">
    <div class="flex flex-col items-center gap-3">
      <p class="font-sans text-sm font-semibold uppercase tracking-[0.08em] text-buckthorn">
        Our Social Impact
      </p>
      <h2 class="font-display font-black uppercase leading-[1.05] tracking-[-0.04em] text-ink text-[2rem] sm:text-5xl lg:text-[4rem]">
        Transforming lives, step by step
      </h2>
    </div>

    <ul class="grid w-full grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {
        impact.map(({ icon, value, label, bg, text }) => (
          <li class={`flex flex-col items-start gap-8 rounded-2xl border-[1.5px] border-woodsmoke p-5 text-left ${bg} ${text}`}>
            <div class="flex h-11 w-11 items-center justify-center rounded-md bg-ink/8">
              <svg class="h-6 w-6" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d={icons[icon]} stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              </svg>
            </div>
            <div class="flex flex-col gap-1">
              <p class="font-display font-black leading-[1.05] tracking-[-0.04em] text-[2rem] sm:text-[2.75rem] lg:text-[4rem]">
                {value}
              </p>
              <p class="font-sans text-base font-normal leading-relaxed tracking-[-0.02em] opacity-80">
                {label}
              </p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
