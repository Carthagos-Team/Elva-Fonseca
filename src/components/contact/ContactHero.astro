---
// Contact / ContactHero — Hero-form (fiel ao Figma node 3196:1129, base 1440).
// Variante de hero exclusiva de Contact: grid 2 colunas (foto + formulário), fundo orchid-100.
// Envio via Web3Forms (100% estático, sem backend — honra a regra #5). A access key é pública
// (pode ir no HTML) e vem de PUBLIC_WEB3FORMS_KEY (.env). Sem a key o form renderiza mas o envio
// falha — gerar grátis em web3forms.com colando o e-mail de destino. Interest field = FAQ.

const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
const thankYouUrl = new URL('/thank-you', Astro.site).toString();

const interests = [
  'General inquiry',
  'Volunteering',
  'Donations & support',
  'Programs & services',
  'Partnerships & collaborations',
];

const fieldWrap = 'flex flex-col gap-2';
const label = 'font-sans text-base font-medium tracking-[-0.02em] text-ink/80';
const control =
  'w-full border-0 border-b border-woodsmoke/20 bg-transparent py-2.5 font-sans text-base text-ink placeholder-ink/40 transition-colors outline-none focus:border-punch';
---

<section data-reveal-section class="border-t border-woodsmoke/10 bg-orchid-100">
  <div class="mx-auto grid max-w-[120rem] grid-cols-1 gap-12 px-6 py-16 sm:px-10 lg:grid-cols-2 lg:items-stretch lg:gap-x-12 lg:px-16 lg:py-20">
    {/* Coluna esquerda — foto */}
    <div class="relative aspect-[4/5] overflow-hidden rounded-md border-[1.5px] border-woodsmoke bg-orchid-050 lg:aspect-auto lg:h-full lg:min-h-[32rem]">
      <img
        src="/images/contact/hero.jpg"
        alt="A community member the foundation supports"
        width="637"
        height="750"
        class="absolute inset-0 size-full object-cover"
        loading="eager"
        decoding="async"
      />
    </div>

    {/* Coluna direita — header + formulário */}
    <div class="flex min-w-0 flex-col justify-center gap-10">
      <div class="flex flex-col gap-6">
        <img src="/images/faq/flower.png" alt="" width="160" height="152" class="h-16 w-auto self-start" aria-hidden="true" />
        <div class="flex flex-col gap-4">
          <h2 class="font-display font-black uppercase leading-[1.05] tracking-[-0.04em] text-ink text-[2rem] sm:text-[2.5rem] lg:text-5xl">
            Open inbox
          </h2>
          <p class="max-w-[34rem] font-sans text-base font-medium leading-relaxed tracking-[-0.02em] text-ink/80">
            Whether you have a question, want to get involved, or simply share your thoughts, your voice
            matters. Together, we can build stronger communities and brighter futures.
          </p>
        </div>
      </div>

      <form action="https://api.web3forms.com/submit" method="POST" class="flex flex-col gap-9">
        {/* Web3Forms — campos de controle */}
        <input type="hidden" name="access_key" value={accessKey} />
        <input type="hidden" name="subject" value="New contact message — Elva Fonseca Foundation" />
        <input type="hidden" name="from_name" value="Elva Fonseca Website" />
        <input type="hidden" name="redirect" value={thankYouUrl} />
        {/* Honeypot anti-spam (deve ficar vazio) */}
        <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <div class="flex flex-col gap-6">
          <div class={fieldWrap}>
            <label for="first_name" class={label}>First Name</label>
            <input id="first_name" name="first_name" type="text" autocomplete="given-name" required class={control} />
          </div>

          <div class={fieldWrap}>
            <label for="last_name" class={label}>Last Name</label>
            <input id="last_name" name="last_name" type="text" autocomplete="family-name" required class={control} />
          </div>

          <div class={fieldWrap}>
            <label for="email" class={label}>Enter your e-mail</label>
            <input id="email" name="email" type="email" autocomplete="email" required class={control} />
          </div>

          <div class={fieldWrap}>
            <label for="interest" class={label}>Interest field</label>
            <div class="relative">
              <select id="interest" name="interest" required class={`${control} appearance-none pr-8 text-ink/60 valid:text-ink`}>
                <option value="" disabled selected>Select</option>
                {interests.map((opt) => <option value={opt}>{opt}</option>)}
              </select>
              <svg
                class="pointer-events-none absolute right-1 top-1/2 size-5 -translate-y-1/2 text-ink"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
            </div>
          </div>
        </div>

        <button
          type="submit"
          class="inline-flex min-h-11 w-fit items-center justify-center rounded-md border-[1.5px] border-woodsmoke bg-buckthorn px-6 py-3.5 font-display font-black text-base uppercase tracking-[-0.01em] text-ink transition-[transform,filter] duration-150 ease-out hover:brightness-105 active:scale-[0.97]"
        >
          Send
        </button>
      </form>
    </div>
  </div>
</section>
