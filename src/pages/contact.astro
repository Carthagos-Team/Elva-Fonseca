---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/global/CtaBand.astro';
---

<BaseLayout title="Contact" description="Get in touch with the Elva Fonseca Foundation.">
  <section class="px-10 py-20">
    <h1 class="font-display text-4xl">Contact</h1>
    <p class="mt-4 max-w-prose text-ink/70">Get in touch with the Elva Fonseca Foundation.</p>
  </section>

  <CtaBand
    titleLines={['So many ways to', 'make a difference.']}
    body={[
      "Whether you're donating, volunteering, or simply spreading the word, you are part of something bigger. Help us continue Elva's legacy of compassion and service.",
    ]}
    ctaLabel="Volunteer"
    ctaHref="/volunteer"
    secondaryLabel="Donate"
    secondaryHref="/donate"
  />
</BaseLayout>
