---
// Thank You — destino do redirect do formulário de Contact (Web3Forms).
// Placeholder enxuto (mesma linha dos stubs); pode ser redesenhado depois.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank you"
  description="Thank you for reaching out to the Elva Fonseca Foundation."
  headerBackground="solid"
>
  <section class="border-t border-woodsmoke/10 bg-orchid-100">
    <div class="mx-auto flex max-w-[75rem] flex-col items-center gap-6 px-6 py-24 text-center sm:px-10 lg:py-32">
      <img src="/images/faq/flower.png" alt="" width="160" height="152" class="h-16 w-auto" aria-hidden="true" />
      <h1 class="font-display font-black uppercase leading-[1.05] tracking-[-0.04em] text-ink text-[2.5rem] sm:text-6xl">
        Thank you!
      </h1>
      <p class="max-w-[34rem] font-sans text-base font-medium leading-relaxed tracking-[-0.02em] text-ink/80">
        Your message has been sent. We'll get back to you soon — thank you for being part of Elva's
        legacy of compassion and service.
      </p>
      <a
        href="/"
        class="mt-2 inline-flex min-h-11 items-center justify-center rounded-md border-[1.5px] border-woodsmoke bg-buckthorn px-6 py-3.5 font-display font-black text-base uppercase tracking-[-0.01em] text-ink transition-[transform,filter] duration-150 ease-out hover:brightness-105 active:scale-[0.97]"
      >
        Back to home
      </a>
    </div>
  </section>
</BaseLayout>
