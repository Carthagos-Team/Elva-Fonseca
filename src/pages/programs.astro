---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/global/Hero.astro';
import ProgramsSlider from '../components/programs/ProgramsSlider.astro';
import WhatIsNext from '../components/programs/WhatIsNext.astro';
import CtaBand from '../components/global/CtaBand.astro';
---

<BaseLayout
  title="Programs"
  description="Community programs supported by the Elva Fonseca Foundation."
  headerTheme="light"
>
  <Hero
    titleLines={['Our Programs']}
    subcopy="Elva Fonseca's legacy is one of care, courage, and generosity, transforming her community through everyday acts of love and solidarity."
    image="/images/hero/programs.jpg"
    imageAlt="A girl standing in a river holding recyclable containers"
  />

  <ProgramsSlider />

  <WhatIsNext />

  <CtaBand
    titleLines={['Do you have a dream project that could benefit your community?']}
    body={[
      "Whether it's a ceramics workshop, cooking classes, a gardening club, or something entirely new, we'd love to hear it.",
    ]}
    ctaLabel="Volunteer"
    ctaHref="/volunteer"
    secondaryLabel="Get in touch"
    secondaryHref="/contact"
  />
</BaseLayout>
