---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/global/Hero.astro';
import Intro from '../components/volunteer/Intro.astro';
---

<BaseLayout
  title="Volunteer"
  description="Join us — volunteer with the Elva Fonseca Foundation."
  headerTheme="light"
>
  <Hero
    titleLines={['Ready to help?', 'Start here']}
    subcopy="Every contribution counts. Support our mission and make lasting impact today."
    image="/images/hero/volunteer.jpg"
    imageAlt="Aerial view of the community at sunset, with a river winding through green fields and homes"
  />

  <Intro />
</BaseLayout>
